<% if flash.any? %>
  <div id="flash-holder">
    <% flash_messages do |flash_type, messages| %>
      <%= content_tag(
            :div,
            h(messages).gsub("\n", "<br>").html_safe,
            class: 'flash',
            id: "message_#{flash_type}"
          ) %>
    <% end %>
  </div>
<% end %>
