<div style="position: relative; display: flex; border: 1px solid #ccc; height: 400px;">
  <!-- Line numbers -->
  <div id="lineNumbers" 
       style="background: #f0f0f0; color: #999; text-align: right; 
              padding: 8px 5px 0 0; user-select: none; line-height: 1.2em; 
              overflow: hidden; white-space: pre;">
    <!-- start empty -->
  </div>

  <!-- Editable text -->
  <div id="robot" contenteditable="true" 
       style="flex: 1; padding: 8px 5px; line-height: 1.2em; 
              white-space: pre-wrap; overflow: auto; outline: none;">
  </div>
</div>

<div class="live_results block" id="barcodes_scanned">0 barcodes</div>

<script>
const editor = document.getElementById('robot');
const lineNumbers = document.getElementById('lineNumbers');

function updateLineNumbers() {
  let text = (editor.innerText || '').replace(/\r/g, '');
  text = text.replace(/^\n+|\n+$/g, ''); // remove leading/trailing empty lines
  let lines = text.split('\n');
  if (lines.length === 0) lines = ['']; // always at least one line
  lineNumbers.textContent = lines.map((_, i) => i + 1).join('\n');
}


// Scroll sync
editor.addEventListener('scroll', () => {
  lineNumbers.scrollTop = editor.scrollTop;
});

// Barcode counting
function find_number_barcodes(text) {
  if (!text) return 0;
  return text.split(/\s+/).filter(s => s.length > 0).length;
}

function recalcNumBarcodes(editorId, maxBarcodes) {
  const text = document.getElementById(editorId).innerText || '';
  const num_barcodes = find_number_barcodes(text);
  const colour = num_barcodes > maxBarcodes ? "red" : "green";

  const display = document.getElementById("barcodes_scanned");
  display.textContent = num_barcodes + " barcodes";
  display.style.color = colour;
}

// Input handler
editor.addEventListener('input', () => {
  updateLineNumbers();
  recalcNumBarcodes('robot', 50);
});

// Initialize
updateLineNumbers();
recalcNumBarcodes('robot', 50);
</script>
